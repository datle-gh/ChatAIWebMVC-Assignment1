@model CreateSubjectViewModel

@{
    ViewData["Title"] = "Thêm môn học mới";
    Layout = "_Layout";
}

<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
    tailwind.config = {
        darkMode: "class",
        theme: {
            extend: {
                colors: {
                    "primary-container": "#4f46e5",
                    "primary-fixed": "#e2dfff",
                    "on-primary": "#ffffff",
                    "surface-container-lowest": "#ffffff",
                    "surface-container": "#eceef0",
                    "surface-container-high": "#e6e8ea",
                    "background": "#f7f9fb",
                    "on-surface": "#191c1e",
                    "on-surface-variant": "#464555",
                    "outline-variant": "#c7c4d8",
                    "error": "#ba1a1a",
                    "error-container": "#ffdad6",
                }
            }
        }
    };
</script>

<div class="bg-background min-h-screen p-6 md:p-10 flex items-start justify-center">
    <div class="w-full max-w-xl">
        <div class="mb-6">
            <a asp-controller="Subject" asp-action="Index"
               class="inline-flex items-center gap-1 text-sm text-on-surface-variant hover:text-primary transition-colors mb-4"
               style="font-family:'Inter',sans-serif;text-decoration:none">
                <span class="material-symbols-outlined text-[18px]">arrow_back</span>
                Quay lại danh sách
            </a>
            <h1 class="text-3xl font-bold text-on-surface" style="font-family:'Be Vietnam Pro',sans-serif">Thêm môn học mới</h1>
            <p class="text-on-surface-variant mt-1" style="font-family:'Inter',sans-serif">Điền thông tin môn học để thêm vào hệ thống.</p>
        </div>

        <div class="bg-surface-container-lowest rounded-2xl p-8 border border-surface-container-high"
             style="box-shadow:0 4px 16px rgba(79,70,229,0.06)">
            <form asp-controller="Subject" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="mb-4 p-3 rounded-xl text-sm" style="background:#ffdad6;color:#ba1a1a;font-family:'Inter',sans-serif"></div>

                <div class="space-y-5">
                    <div>
                        <label asp-for="SubjectCode" class="block text-sm font-semibold text-on-surface mb-1.5" style="font-family:'Inter',sans-serif"></label>
                        <input asp-for="SubjectCode" type="text" placeholder="VD: CS101"
                               class="w-full px-4 py-3 rounded-xl border border-outline-variant bg-white text-on-surface outline-none transition-all focus:border-primary-container focus:ring-2"
                               style="font-family:'Inter',sans-serif;--tw-ring-color:rgba(79,70,229,0.2)" />
                        <span asp-validation-for="SubjectCode" class="text-xs text-error mt-1 block" style="font-family:'Inter',sans-serif"></span>
                    </div>

                    <div>
                        <label asp-for="SubjectName" class="block text-sm font-semibold text-on-surface mb-1.5" style="font-family:'Inter',sans-serif"></label>
                        <input asp-for="SubjectName" type="text" placeholder="VD: Nhập môn lập trình"
                               class="w-full px-4 py-3 rounded-xl border border-outline-variant bg-white text-on-surface outline-none transition-all focus:border-primary-container focus:ring-2"
                               style="font-family:'Inter',sans-serif;--tw-ring-color:rgba(79,70,229,0.2)" />
                        <span asp-validation-for="SubjectName" class="text-xs text-error mt-1 block" style="font-family:'Inter',sans-serif"></span>
                    </div>

                    <div>
                        <label asp-for="Description" class="block text-sm font-semibold text-on-surface mb-1.5" style="font-family:'Inter',sans-serif"></label>
                        <textarea asp-for="Description" rows="3" placeholder="Mô tả ngắn về môn học này..."
                                  class="w-full px-4 py-3 rounded-xl border border-outline-variant bg-white text-on-surface outline-none transition-all focus:border-primary-container resize-none"
                                  style="font-family:'Inter',sans-serif"></textarea>
                        <span asp-validation-for="Description" class="text-xs text-error mt-1 block" style="font-family:'Inter',sans-serif"></span>
                    </div>
                </div>

                <div class="mt-8 flex gap-3">
                    <button type="submit"
                            class="flex-1 py-3 rounded-xl font-semibold text-white transition-all active:scale-95 shadow-sm hover:shadow-md"
                            style="background:#4f46e5;font-family:'Inter',sans-serif">
                        Tạo môn học
                    </button>
                    <a asp-controller="Subject" asp-action="Index"
                       class="flex-1 py-3 rounded-xl font-semibold text-on-surface text-center transition-all active:scale-95 border border-outline-variant hover:bg-surface-container"
                       style="font-family:'Inter',sans-serif;text-decoration:none">
                        Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
